# ---------------------------------------------------------------------------
# Root environment example.
# Copy to `.env` for `docker compose up`. Per-app examples also live in
# apps/server/.env.example and apps/web/.env.example for non-Docker dev.
# Never commit real secrets.
# ---------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
# Used by docker-compose to provision the local Postgres container.
POSTGRES_USER=betterreviews
POSTGRES_PASSWORD=betterreviews
POSTGRES_DB=betterreviews

# Connection string the server uses. Inside Docker the host is the `db`
# service; for non-Docker local dev use localhost (see apps/server/.env.example).
DATABASE_URL=postgres://betterreviews:betterreviews@db:5432/betterreviews

# --- Server -----------------------------------------------------------------
PORT=4000
NODE_ENV=development

# Local-development-only mock auth. When set, requests with no auth header are
# treated as this user. The web client also sends it via `x-mock-user-id`.
# This matches the seeded test user.
MOCK_USER_ID=00000000-0000-0000-0000-000000000001

# --- Supabase (staging/production — optional locally) -----------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Web client (Vite) ------------------------------------------------------
# The browser runs on the host, so it reaches the server via the published port.
VITE_API_BASE_URL=http://localhost:4000
VITE_MOCK_USER_ID=00000000-0000-0000-0000-000000000001
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
