# Web client environment example (non-Docker local dev).
# Copy to apps/web/.env.local and adjust. Vite only exposes VITE_-prefixed vars.

VITE_API_BASE_URL=http://localhost:4000

# Local-development-only mock auth: the client sends this as `x-mock-user-id`
# so saves/recommendations are attributed to the seeded test user.
VITE_MOCK_USER_ID=00000000-0000-0000-0000-000000000001

# Supabase (future client-side auth) — optional locally.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
