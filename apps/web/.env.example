# Web client environment example (non-Docker local dev).
# Copy to apps/web/.env.local and adjust. Vite only exposes VITE_-prefixed vars.

VITE_API_BASE_URL=http://localhost:4000

# --- Workflow A: mock auth (no Supabase) -----------------------------------
# When Supabase vars below are blank, the client runs in mock mode and sends
# this id as `x-mock-user-id`.
# VITE_MOCK_USER_ID=00000000-0000-0000-0000-000000000001

# --- Workflow B: local Supabase (real magic-link auth) ---------------------
# When these are set, the client uses Supabase Auth and sends the session's
# access token as a Bearer. The anon key is the well-known LOCAL demo key.
VITE_SUPABASE_URL=http://127.0.0.1:54721
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
# Local mailbox (Mailpit/Inbucket) — shown as a hint after sending a magic link.
VITE_INBUCKET_URL=http://localhost:54724
