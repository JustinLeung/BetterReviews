# Server environment example (non-Docker local dev).
# Copy to apps/server/.env and adjust. Never commit real secrets.
#
# Two local workflows are supported:
#   A) Plain Docker Postgres + mock auth  (the `docker compose up` path)
#   B) Local Supabase stack + real magic-link auth  (`supabase start`)
# Fill in the section for the workflow you're using.

PORT=4000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173

# --- Workflow A: plain Postgres + mock auth --------------------------------
# DATABASE_URL=postgres://betterreviews:betterreviews@localhost:5432/betterreviews
# MOCK_USER_ID=00000000-0000-0000-0000-000000000001   # local-dev-only mock auth

# --- Workflow B: local Supabase (real auth) --------------------------------
# Points at the Supabase stack's Postgres + GoTrue. The keys below are the
# well-known LOCAL demo keys printed by `supabase status` (not secrets).
# Leave MOCK_USER_ID unset so writes require a real signed-in user.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54722/postgres
SUPABASE_URL=http://127.0.0.1:54721
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# NOTE: this project's local Supabase ports were remapped to 5472x in
# supabase/config.toml to avoid clashing with other local Supabase projects.
