# Server environment example (non-Docker local dev).
# Copy to apps/server/.env and adjust. Never commit real secrets.

PORT=4000
NODE_ENV=development

# For local dev outside Docker, Postgres is reachable on localhost.
# (Inside Docker the host is the `db` service — see root .env.example.)
DATABASE_URL=postgres://betterreviews:betterreviews@localhost:5432/betterreviews

# Local-development-only mock auth. Requests with no auth header act as this
# user. Matches the seeded test user. DO NOT use mock auth in production.
MOCK_USER_ID=00000000-0000-0000-0000-000000000001

# Comma-separated allowed CORS origins for the web client.
CORS_ORIGINS=http://localhost:5173

# --- Supabase (optional locally; required for staging/production) -----------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
